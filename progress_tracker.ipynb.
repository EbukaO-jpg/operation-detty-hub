        "import datetime\n",
        "\n",
        "def main():\n",
        "    print(\"--- OPERATION DETTY: COMMAND CENTER ---\")\n",
        "    date_today = datetime.date.today()\n",
        "\n",
        "    # 1. Input your progress\n",
        "    weight = float(input(\"Enter current weight (kg): \"))\n",
        "    coding_topic = input(\"What did you study today? \")\n",
        "    hours = float(input(\"How many hours did you put in? \"))\n",
        "\n",
        "    # 2. Progress Logic\n",
        "    weight_goal = 95.0\n",
        "    diff = weight - weight_goal\n",
        "\n",
        "    # 3. The Report\n",
        "    print(f\"\\n--- LOG FOR {date_today} ---\")\n",
        "    print(f\"STANCE: {coding_topic} for {hours} hours.\")\n",
        "\n",
        "    if diff > 0:\n",
        "        print(f\"FITNESS: {diff:.1f} kg away from target (95kg).\")\n",
        "    else:\n",
        "        print(\"FITNESS: Target reached. Maintain form.\")\n",
        "\n",
        "    print(\"\\n[Status: Saved to operation-detty-hub]\")\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    main()\n"
